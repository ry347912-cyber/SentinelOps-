# ─── AIOps Platform Environment Configuration ────────────────────────────────
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Required: Anthropic AI ──────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=aiops-dev-secret-change-this-in-production-abc123
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed)
DATABASE_URL=sqlite:///./aiops.db

# PostgreSQL (production recommended)
# DATABASE_URL=postgresql://aiops_user:password@localhost:5432/aiops_db

# ─── App ──────────────────────────────────────────────────────────────────────
DEBUG=false
APP_NAME=AIOps Platform

# ─── CORS Origins ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─── Incident Detection Thresholds ────────────────────────────────────────────
CPU_THRESHOLD=85.0
MEMORY_THRESHOLD=90.0
ERROR_RATE_THRESHOLD=10
ANOMALY_CONFIDENCE_THRESHOLD=0.7

# ─── Background Tasks ─────────────────────────────────────────────────────────
INCIDENT_SCAN_INTERVAL=60
LOG_ANALYSIS_INTERVAL=30

# ─── Optional: Email Alerts ───────────────────────────────────────────────────
# ALERT_EMAIL=ops-team@company.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
